# ============================================================
# Python
# ============================================================

__pycache__/
*.py[cod]
*$py.class


# ============================================================
# Virtual environments
# ============================================================

venv/
.venv/
env/


# ============================================================
# VS Code / IDE
# ============================================================

.vscode/
.idea/


# ============================================================
# Operating system files
# ============================================================

Thumbs.db
Desktop.ini
.DS_Store


# ============================================================
# Logs and runtime outputs
# ============================================================

*.log

Assembly_monitor/logs/
Assembly_monitor/recordings/


# ============================================================
# RAW DATASET FILES
# ============================================================
#
# Raw videos and automatically generated recording metadata
# are working data and should not be committed to Git.
# ============================================================

datasets/raw/videos/*
datasets/raw/metadata/*


# ============================================================
# EXTRACTED DATASET FILES
# ============================================================
#
# Images extracted from videos and generated frame manifests
# are reproducible outputs of extract_frames.py.
# ============================================================

datasets/extracted/images/*
datasets/extracted/metadata/*


# ============================================================
# DATASET QUALITY REPORTS
# ============================================================
#
# Automatically generated by:
#
# check_dataset_quality.py
# detect_near_duplicates.py
# ============================================================

datasets/quality/*


# ============================================================
# DATASET REVIEW OUTPUTS
# ============================================================
#
# Generated dataset review manifests are kept outside Git.
#
# Important:
# Human review decisions stored here should be backed up
# separately during real thesis data collection.
# ============================================================

datasets/review/*


# ============================================================
# YOLO DATASET IMAGES
# ============================================================
#
# Final working YOLO images should not be committed because
# real datasets can become very large.
# ============================================================

datasets/images/*
datasets/train/images/*
datasets/val/images/*
datasets/test/images/*


# ============================================================
# YOLO DATASET LABELS
# ============================================================
#
# Annotation labels generated during dataset development.
#
# We ignore the working labels here.
# Later, a small curated example dataset can be committed under
# a separate examples/ directory for portfolio demonstration.
# ============================================================

datasets/labels/*
datasets/train/labels/*
datasets/val/labels/*
datasets/test/labels/*


# ============================================================
# YOLO / ULTRALYTICS GENERATED OUTPUTS
# ============================================================

runs/


# ============================================================
# MODEL WEIGHTS AND EXPORTED MODELS
# ============================================================

*.pt
*.pth
*.onnx
*.engine


# ============================================================
# VIDEO FILES
# ============================================================

*.mp4
*.avi
*.mov
*.mkv


# ============================================================
# TEMPORARY FILES
# ============================================================

*.tmp
*.temp


# ============================================================
# JUPYTER NOTEBOOK CHECKPOINTS
# ============================================================

.ipynb_checkpoints/


# ============================================================
# PYTHON TEST / TOOL CACHES
# ============================================================

.pytest_cache/
.mypy_cache/
.ruff_cache/


# ============================================================
# KEEP DATASET DIRECTORY STRUCTURE
# ============================================================
#
# Git does not track empty directories.
#
# These exceptions allow .gitkeep placeholder files to preserve
# the intended project structure.
# ============================================================

!datasets/raw/videos/.gitkeep
!datasets/raw/metadata/.gitkeep

!datasets/extracted/images/.gitkeep
!datasets/extracted/metadata/.gitkeep

!datasets/quality/.gitkeep
!datasets/review/.gitkeep


# ============================================================
# OPTIONAL CURATED EXAMPLE DATA
# ============================================================
#
# Later we can create an examples/ directory containing a very
# small demonstration dataset, example annotations, reports,
# and inference outputs for GitHub/recruiter demonstration.
#
# The examples directory is intentionally NOT ignored.
# ============================================================