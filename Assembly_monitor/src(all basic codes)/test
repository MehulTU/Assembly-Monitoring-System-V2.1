import cv2

cap = cv2.VideoCapture(0) # Change the index to 1 or 2 if you have multiple cameras

while True:
    ret, frame = cap.read()

    print(ret)

    if ret:
        cv2.imshow("D415", frame)

    # read a key press (returns -1 if no key pressed)
    key = cv2.waitKey(1) & 0xFF
    # ESC key
    if key == 27:
        break
    # 'q' key
    if key == ord("q"):
        break

cap.release()
cv2.destroyAllWindows()